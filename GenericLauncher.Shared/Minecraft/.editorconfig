root = true

[*.cs]

# Always require braces for control blocks
csharp_prefer_braces = true:error
csharp_trailing_comma_in_multiline_lists = true

# Prevent single-line statements that hide braces
csharp_preserve_single_line_statements = false
csharp_preserve_single_line_blocks = true
csharp_style_expression_bodied_properties = when_possible:silent

# Consistent indentation
indent_style = space
indent_size = 4

# Rider / ReSharper enforcement
resharper_braces_for_ifelse = required
resharper_braces_for_for = required
resharper_braces_for_foreach = required
resharper_braces_for_while = required
resharper_braces_for_dowhile = required
resharper_braces_for_using = required
resharper_braces_for_lock = required
resharper_braces_for_fixed = required
resharper_csharp_trailing_comma_in_multiline_lists = true
resharper_csharp_indent_style = space
resharper_csharp_indent_size = 4
